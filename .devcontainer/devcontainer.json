{
  "name": "HYROI Smart Scorer",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20"
    }
  },
  "postCreateCommand": "cd backend && pip install -r requirements.txt 2>/dev/null || true",
  "forwardPorts": [3000, 8000],
  "portsAttributes": {
    "3000": { "label": "Frontend - Next.js" },
    "8000": { "label": "Backend - FastAPI" }
  },
  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}/backend"
  }
}
